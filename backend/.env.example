# Database — async driver for the app, sync driver for Alembic migrations
DATABASE_URL=postgresql+asyncpg://dawah:dawah_pass@localhost:5432/dawah_db
DATABASE_URL_SYNC=postgresql+psycopg2://dawah:dawah_pass@localhost:5432/dawah_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI — OpenAI API key
OPENAI_API_KEY=sk-proj-...

# Payments — Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
DEBUG=true

# Rate limiting (AI questions per day)
QA_DAILY_LIMIT_ANONYMOUS=5
QA_DAILY_LIMIT_USER=20
